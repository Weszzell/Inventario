DATABASE_URL="postgresql://inventory:change-this-password@postgres:5432/inventory?schema=public"
SESSION_COOKIE_NAME="__Host-web_inventory_session"
SESSION_MAX_AGE="43200"
SESSION_SECURE="true"
SESSION_SAME_SITE="strict"
SESSION_DOMAIN=""
ALLOW_INSECURE_LOCALHOST_SESSION="false"
STRICT_ENV_VALIDATION="false"
STATUS_PUBLIC_DETAILS="false"
MONITORING_LOG_REQUESTS="false"
MONITORING_SLOW_REQUEST_MS="1000"
NUXT_PUBLIC_APP_NAME="Web Inventory"
NUXT_PUBLIC_APP_ENV="production"
POSTGRES_DB="inventory"
POSTGRES_USER="inventory"
POSTGRES_PASSWORD="change-this-password"
